---
import siteConfig from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;

// Deterministic hash so each project always gets the same "generated" visual.
function hashString(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = (hash << 5) - hash + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

function hslFromHash(hash: number, offset: number, s: number, l: number) {
  const hue = (hash + offset) % 360;
  return `hsl(${hue}, ${s}%, ${l}%)`;
}
---

{
  hasProjects && (
    <section id="projects" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4 reveal">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Projects
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
              {siteConfig.projects.map((project, index) => {
                const Component = project.link ? "a" : "div";
                const linkProps = project.link
                  ? {
                      href: project.link,
                      target: "_blank",
                      rel: "noopener noreferrer",
                    }
                  : {};

                const hash = hashString(project.name);
                const colorA = hslFromHash(hash, 0, 70, 70);
                const colorB = hslFromHash(hash, 70, 75, 65);
                const colorC = hslFromHash(hash, 140, 65, 75);
                const angle = hash % 360;

                return (
                  <Component
                    {...linkProps}
                    class="project-card reveal group relative flex flex-col bg-white rounded-xl sm:rounded-2xl border border-gray-200 overflow-hidden transition-all duration-300 hover:shadow-xl hover:border-gray-300"
                    style={`transition-delay: ${index * 70}ms`}
                    data-tilt
                  >
                    {/* Generated abstract header */}
                    <div
                      class="relative h-32 sm:h-36 overflow-hidden"
                      style={`background: linear-gradient(${angle}deg, ${colorA}, ${colorB} 50%, ${colorC});`}
                    >
                      <div class="project-blob absolute -inset-6 opacity-60 mix-blend-overlay" />
                      <span class="absolute top-3 left-4 text-xs font-mono text-white/80 tracking-wider">
                        0{index + 1}
                      </span>

                      {project.link && (
                        <div class="absolute top-3 right-3 w-9 h-9 flex items-center justify-center bg-white/20 backdrop-blur-sm rounded-full text-white transition-all duration-300 group-hover:bg-white/35 group-hover:scale-110">
                          <svg
                            class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M7 17L17 7M17 7H7M17 7V17"
                            />
                          </svg>
                        </div>
                      )}

                      <h3 class="absolute bottom-3 left-4 right-4 text-lg sm:text-xl font-bold text-white drop-shadow-sm leading-tight">
                        {project.name}
                      </h3>
                    </div>

                    <div class="flex-1 flex flex-col p-4 sm:p-5 space-y-3">
                      <p class="text-sm sm:text-base text-gray-600 leading-relaxed">
                        {project.description}
                      </p>

                      {project.skills && project.skills.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 pt-1 mt-auto">
                          {project.skills.map((skill) => (
                            <span class="px-2.5 py-1 bg-gray-900 text-white rounded-md text-xs font-medium transition-colors duration-300 group-hover:bg-gray-800">
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </Component>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .project-blob {
    background-image:
      radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.5), transparent 50%),
      radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.3), transparent 50%);
    transition: transform 0.6s ease;
  }

  .project-card:hover .project-blob {
    transform: scale(1.15) rotate(8deg);
  }

  .project-card {
    transform-style: preserve-3d;
    will-change: transform;
  }
</style>

<script>
  // Subtle cursor-follow tilt on project cards. Skipped on touch devices and
  // for users who prefer reduced motion. No <ClientRouter /> on this site,
  // so DOMContentLoaded is the real trigger.
  function initTilt() {
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isTouch = window.matchMedia("(hover: none)").matches;
    if (prefersReduced || isTouch) return;

    const cards = document.querySelectorAll<HTMLElement>("[data-tilt]:not([data-tilt-bound])");

    cards.forEach((card) => {
      card.setAttribute("data-tilt-bound", "true");
      const strength = 8; // max degrees of tilt

      function handleMove(e: MouseEvent) {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(800px) rotateY(${x * strength}deg) rotateX(${-y * strength}deg) translateY(-4px)`;
      }

      function handleLeave() {
        card.style.transform = "";
      }

      card.addEventListener("mousemove", handleMove);
      card.addEventListener("mouseleave", handleLeave);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTilt);
  } else {
    initTilt();
  }
  document.addEventListener("astro:page-load", initTilt);
</script>
