---
import siteConfig from "../config";
const hasActivities = siteConfig.activities && siteConfig.activities.length > 0;
---

{
  hasActivities && (
    <section id="activities" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4 reveal">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Beyond Code
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            <p class="mt-4 text-sm sm:text-base text-gray-500 max-w-xs">
              Clubs, councils, and campus chaos I help run when I'm not at a keyboard.
            </p>
          </div>

          <div class="lg:col-span-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-5">
              {siteConfig.activities.map((activity, index) => (
                <div
                  class="activity-card reveal group relative bg-white rounded-xl sm:rounded-2xl border border-gray-200 p-4 sm:p-5 md:p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-gray-300"
                  style={`transition-delay: ${index * 60}ms`}
                >
                  <div class="flex items-start justify-between mb-3">
                    <span
                      class="text-2xl sm:text-3xl inline-block transition-transform duration-300 group-hover:scale-125 group-hover:-rotate-6"
                      aria-hidden="true"
                    >
                      {activity.emoji}
                    </span>
                    <span class="text-xs text-gray-400 font-mono mt-1">
                      {activity.dateRange}
                    </span>
                  </div>

                  <h3 class="text-base sm:text-lg font-semibold text-gray-900 leading-snug">
                    {activity.role}
                  </h3>
                  <p
                    class="text-sm sm:text-base mt-0.5 font-medium"
                    style={`color: ${siteConfig.accentColor}`}
                  >
                    {activity.org}
                  </p>

                  <ul class="mt-3 space-y-1.5">
                    {activity.bullets.map((bullet) => (
                      <li class="flex items-start">
                        <span class="inline-block w-1 h-1 rounded-full bg-gray-400 mt-2 mr-2.5 flex-shrink-0" />
                        <span class="text-xs sm:text-sm text-gray-600 leading-relaxed">
                          {bullet}
                        </span>
                      </li>
                    ))}
                  </ul>

                  <div
                    class="absolute inset-x-0 bottom-0 h-1 rounded-b-xl sm:rounded-b-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300"
                    style={`background-color: ${siteConfig.accentColor}`}
                  />
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
